# Server
PORT=5000

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=delivery_app
DB_PORT=3306

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Email (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Delivery App <your_email@gmail.com>"

# OTP
OTP_EXPIRY_MINUTES=15
OTP_LENGTH=6

# HyperPay (Copy&Pay - sandbox)
HYPERPAY_BASE_URL=https://eu-test.oppwa.com
HYPERPAY_ENTITY_ID=YOUR_HYPERPAY_ENTITY_ID
HYPERPAY_ACCESS_TOKEN=YOUR_HYPERPAY_ACCESS_TOKEN
HYPERPAY_CURRENCY=YOUR_HYPERPAY_CURRENCY

# AI Chatbot (Google Gemini) - get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-flash-latest

# Environment
NODE_ENV=development
